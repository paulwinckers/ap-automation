# Copy to .env and fill in your values
# Never commit .env to git

# Aspire
ASPIRE_BASE_URL=https://cloud-api.youraspire.com
ASPIRE_TOKEN_URL=https://cloud-api.youraspire.com/token
ASPIRE_CLIENT_ID=
ASPIRE_CLIENT_SECRET=
ASPIRE_SANDBOX=true   # set false for production

# QBO
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REALM_ID=
QBO_REFRESH_TOKEN=
QBO_SANDBOX=true      # set false for production

# Anthropic
ANTHROPIC_API_KEY=

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
D1_DATABASE_ID=
R2_BUCKET_NAME=ap-invoices
CF_ACCESS_TEAM_DOMAIN=

# App
DEBUG=true
LOG_LEVEL=DEBUG
